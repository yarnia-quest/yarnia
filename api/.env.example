# Yarnia BACKEND (api/ Worker + instant/) — copy to api/.env (gitignored) and fill in.
#
# Server-side ONLY. These values run on Cloudflare / in CI and must NEVER be imported
# into app/ (the client bundle). Mirror the SECRET keys as GitHub repo secrets
# (Settings -> Secrets and variables -> Actions) for CI deploys + schema push.
#
# Note: `wrangler dev` reads secrets from api/.dev.vars, not .env. api/.env is the
# human source of truth; the api dev script loads it (see api/README.md). Production
# secrets are set with `wrangler secret put` / GitHub Actions secrets.

# --- InstantDB ---
# Public app id (also lives in app/.env as EXPO_PUBLIC_INSTANT_APP_ID; not a secret):
INSTANT_APP_ID=
# SECRET: dashboard -> your app -> Admin SDK. Used by the Worker at runtime + instant schema/seed.
INSTANT_ADMIN_TOKEN=

# --- Story generation (Qwen via DashScope, OpenAI-compatible) ---
# SECRET: DashScope/Qwen API key (story text). Get one at Alibaba Cloud Model Studio.
# Client uses the Singapore/intl endpoint by default (dashscope-intl.aliyuncs.com).
QWEN_API_KEY=

# --- Voice / TTS ---
# SECRET: ElevenLabs API key (narration audio). Used by the Worker at runtime.
ELEVENLABS_API_KEY=

# --- Cloudflare deploy / CI (shared with marketing; local dev can use `wrangler login` instead) ---
CLOUDFLARE_ACCOUNT_ID=
CLOUDFLARE_ZONE_ID=
# SECRET: dash.cloudflare.com -> My Profile -> API Tokens ("Edit Cloudflare Workers").
CLOUDFLARE_API_TOKEN=
