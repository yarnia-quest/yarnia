# secrets / local config — NEVER commit
.env
.env.local
.dev.vars

# deps / build
# No trailing slash: matches node_modules whether it's a real directory OR a symlink
# (worktrees symlink api/ and instant/ node_modules to main's install — a trailing
# slash would skip those symlinks and leave them showing as untracked).
node_modules
.wrangler/
dist/
.next/

# os / editor
.DS_Store
*.log
.gstack/

# bun (we standardize on npm; gstack's own CLI uses bun separately)
bun.lock
bun.lockb

# installed agent skills: .agents/ is the materialized copy (like node_modules,
# ignored). skills-lock.json is the committed manifest — restore with
# `npx skills experimental_install`.
.agents/

# Local /story test artifacts (npm run story)
api/story.mp3
*.mp3

# Per-worktree dev-server port (set by scripts/worktree-add.sh); never shared
.dev.port
