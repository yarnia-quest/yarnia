# Yarnia config — copy to .env (gitignored) and fill in.
# Mirror these as GitHub repo secrets (Settings -> Secrets and variables -> Actions) for CI deploys.

# --- Cloudflare (account/zone are identifiers, not secrets) ---
CLOUDFLARE_ACCOUNT_ID=
CLOUDFLARE_ZONE_ID=
# SECRET: create at dash.cloudflare.com (My Profile -> API Tokens, "Edit Cloudflare Workers"). Local dev can use `wrangler login` instead.
CLOUDFLARE_API_TOKEN=

# --- InstantDB ---
# Public app id (safe to expose in client code):
INSTANT_APP_ID=
# SECRET: dashboard -> your app -> Admin SDK. Used by the Worker at runtime.
INSTANT_ADMIN_TOKEN=
# SECRET: Personal Access Token (per_...) from dashboard settings — used by instant-cli for schema push in CI.
INSTANT_PERSONAL_ACCESS_TOKEN=

# --- Frontend (not secret) ---
# Deployed Worker URL; set as the <form action> in marketing/index.html.
SIGNUP_WORKER_URL=
