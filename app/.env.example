# Yarnia FRONTEND (Expo / app/) — copy to app/.env (gitignored) and fill in.
#
# ⚠️ CLIENT BUNDLE: everything in this file ships inside the app on the user's device
# and is fully readable by anyone. PUT NO SECRETS HERE. Only public, safe-to-expose values.
# Expo only exposes vars prefixed EXPO_PUBLIC_ to the app, so that prefix is required.
# Secrets (admin token, API keys) live in api/.env and NEVER cross into this file.

# InstantDB public app id (safe in client code — it is the public identifier):
EXPO_PUBLIC_INSTANT_APP_ID=

# Base URL of the product backend Worker (api/), e.g. https://api.yarnia.quest
EXPO_PUBLIC_API_BASE_URL=
