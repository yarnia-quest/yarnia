# Yarnia FRONTEND (Flutter / app/) — public config reference.
#
# ⚠️ CLIENT BUNDLE: everything the client reads ships inside the app on the user's
# device and is fully readable by anyone. PUT NO SECRETS HERE. Only public,
# safe-to-expose values. Secrets (admin token, API keys) live in api/.env and
# NEVER cross into the client.
#
# How the Flutter client actually reads config: at build/run time via Dart
# compile-time defines, not a .env file. See app/flutter/dart_defines/*.json and
# pass them with --dart-define-from-file, e.g.:
#   flutter run        --dart-define-from-file=dart_defines/local.json -d chrome
#   flutter build web --release --dart-define-from-file=dart_defines/prod.json
# Read in code with String.fromEnvironment('NAME') (see app/flutter/lib/main.dart).

# Base URL of the product backend Worker (api/), e.g. https://api.yarnia.quest
# (key name: API_BASE — see dart_defines/prod.json and dart_defines/local.json)
API_BASE=https://api.yarnia.quest
