---
import YarniaApp from "@/components/YarniaApp.tsx";
import BaseLayout from "@/layouts/BaseLayout.astro";
import "@/styles/global.css";
---

<BaseLayout>
  <YarniaApp client:only="preact" />
</BaseLayout>

<style>
  :global(.screen) {
    min-height: 100dvh;
    display: flex;
    flex-direction: column;
  }

  :global(.btn-primary) {
    background: var(--color-gold);
    color: var(--color-navy);
    border: none;
    border-radius: 9999px;
    padding: 0.75rem 2.5rem;
    font-family: var(--font-lora), Georgia, serif;
    font-size: 1rem;
    font-weight: 700;
    letter-spacing: 0.05em;
    cursor: pointer;
    transition: opacity 0.2s;
  }

  :global(.btn-primary:hover) {
    opacity: 0.85;
  }

  :global(.btn-outline) {
    background: transparent;
    color: var(--color-gold);
    border: 1.5px solid var(--color-gold);
    border-radius: 9999px;
    padding: 0.7rem 2.25rem;
    font-family: var(--font-lora), Georgia, serif;
    font-size: 0.9rem;
    letter-spacing: 0.06em;
    cursor: pointer;
    transition: opacity 0.2s;
  }

  :global(.btn-outline:hover) {
    opacity: 0.75;
  }

  :global(.chip) {
    background: rgba(241, 198, 115, 0.1);
    color: var(--color-cream);
    border: 1px solid rgba(241, 198, 115, 0.3);
    border-radius: 9999px;
    padding: 0.6rem 1.25rem;
    font-family: var(--font-lora), Georgia, serif;
    font-size: 0.95rem;
    cursor: pointer;
    transition: background 0.2s, border-color 0.2s;
  }

  :global(.chip:hover) {
    background: rgba(241, 198, 115, 0.2);
    border-color: rgba(241, 198, 115, 0.6);
  }

  :global(.mic-btn) {
    width: 4rem;
    height: 4rem;
    border-radius: 50%;
    background: rgba(241, 198, 115, 0.12);
    border: 1.5px solid rgba(241, 198, 115, 0.3);
    font-size: 1.5rem;
    cursor: pointer;
    transition: background 0.2s, border-color 0.2s, transform 0.2s;
    display: flex;
    align-items: center;
    justify-content: center;
  }

  :global(.mic-btn:hover) {
    background: rgba(241, 198, 115, 0.2);
  }

  :global(.mic-btn--active) {
    background: rgba(241, 198, 115, 0.25);
    border-color: var(--color-gold);
    animation: pulse 1.5s ease-in-out infinite;
  }

  @keyframes pulse {
    0%, 100% { transform: scale(1); }
    50% { transform: scale(1.1); }
  }
</style>
