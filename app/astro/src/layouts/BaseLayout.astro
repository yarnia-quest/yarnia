---
import { Font } from "astro:assets";

interface Props {
  title?: string;
  description?: string;
}

const {
  title = "Yarnia — Bedtime stories that remember your child",
  description = "A screen-off voice story app that tells your child a personalized bedtime story and remembers them across nights.",
} = Astro.props;
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <meta name="description" content={description} />
    <title>{title}</title>
    <Font cssVariable="--font-fraunces" preload />
    <Font cssVariable="--font-lora" preload />
    <slot name="head" />
  </head>
  <body>
    <slot />
  </body>
</html>
