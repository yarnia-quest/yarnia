---
import { Image } from "astro:assets";

interface Props {
  src: ImageMetadata;
  alt: string;
  gradient: string;
  class?: string;
  eager?: boolean;
  sizes?: string;
  widths?: number[];
  quality?: number;
  format?: "avif" | "webp" | "png" | "jpg" | "jpeg";
}

const DEFAULT_WIDTHS = [360, 480, 640, 768, 1024, 1280];
const DEFAULT_SIZES = "100vw";

const {
  src,
  alt,
  gradient,
  class: className,
  eager = false,
  sizes = DEFAULT_SIZES,
  widths = DEFAULT_WIDTHS,
  quality,
  format,
} = Astro.props;
---

<div class:list={["prism-image", className]}>
  <Image
    src={src}
    alt={alt}
    loading={eager ? "eager" : "lazy"}
    fetchpriority={eager ? "high" : "auto"}
    widths={widths}
    sizes={sizes}
    quality={quality}
    format={format}
  />
  <div class="prism-image__gradient" style={{ background: gradient }} />
</div>

<style>
  .prism-image {
    overflow: hidden;
    position: relative;
  }
  .prism-image :global(img) {
    width: 100%;
    height: 100%;
    object-fit: cover;
    display: block;
  }
  .prism-image__gradient {
    position: absolute;
    inset: 0;
    opacity: 0;
    transition: opacity 0.5s ease;
    pointer-events: none;
  }
</style>
